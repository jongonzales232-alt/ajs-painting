generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  SCHEDULED
  QUOTED
  WON
  LOST
  COMPLETED
}

enum SurfaceType {
  INTERIOR
  EXTERIOR
  BOTH
}

model Lead {
  id                 String         @id @default(cuid())
  fullName           String
  phone              String
  email              String
  address            String
  projectType        String
  surface            SurfaceType
  projectSize        String
  preferredStartDate DateTime?
  description        String
  status             LeadStatus     @default(NEW)
  adminNotes         String         @default("")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  photos             LeadPhoto[]
  followUpNotes      FollowUpNote[]
}

model LeadPhoto {
  id        String   @id @default(cuid())
  leadId    String
  url       String
  filename  String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model FollowUpNote {
  id        String   @id @default(cuid())
  leadId    String
  note      String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Appointment {
  id        String   @id @default(cuid())
  fullName  String
  phone     String
  email     String
  address   String
  notes     String   @default("")
  startsAt  DateTime @unique
  endsAt    DateTime
  createdAt DateTime @default(now())
}

model AvailabilitySlot {
  id        String   @id @default(cuid())
  weekday   Int
  startTime String
  endTime   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model BlockedDay {
  id        String   @id @default(cuid())
  date      DateTime @unique
  reason    String   @default("")
  createdAt DateTime @default(now())
}

model GalleryPhoto {
  id          String   @id @default(cuid())
  title       String?
  description String?
  jobType     String?
  jobDate     DateTime?
  url         String
  filename    String
  createdAt   DateTime @default(now())
}

model SiteAsset {
  key       String   @id
  url       String
  filename  String
  alt       String   @default("")
  updatedAt DateTime @updatedAt
}

model RateLimitBucket {
  key     String   @id
  count   Int      @default(0)
  resetAt DateTime
}
