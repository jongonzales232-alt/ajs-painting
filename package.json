{
  "name": "ajs-painting",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "render:build": "prisma generate && next build",
    "render:start": "node scripts/render-start.mjs",
    "lint": "eslint .",
    "preflight:launch": "node scripts/preflight-launch.mjs",
    "clean:test-data": "node scripts/clean-test-data.mjs",
    "db:setup": "node prisma/setup-sqlite.js && prisma generate && node prisma/seed.js",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "next": "^15.3.3",
    "prisma": "^6.9.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
